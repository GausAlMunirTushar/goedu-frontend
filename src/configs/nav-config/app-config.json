    "global_permissions": {
        "DASHBOARD_VIEW": "Access main dashboard",
        "ACADEMIC_MODULE_ACCESS": "Access Academic module",
        "STUDENT_MODULE_ACCESS": "Access Student module",
        "TEACHER_MODULE_ACCESS": "Access Teacher module",
        "STAFF_MODULE_ACCESS": "Access Staff module",
        "ATTENDANCE_MODULE_ACCESS": "Access Attendance module",
        "SUBJECT_MODULE_ACCESS": "Access Subject module",
        "ROUTINE_MODULE_ACCESS": "Access Routine module",
        "EXAMINATION_MODULE_ACCESS": "Access Examination module",
        "RESULT_MODULE_ACCESS": "Access Result module",
        "NOTICE_MODULE_ACCESS": "Access Notice module",
        "WEBSITE_MODULE_ACCESS": "Access Website module",
        "REPORTS_MODULE_ACCESS": "Access Reports module",
        "SUPER_ADMIN": "Full system access"
