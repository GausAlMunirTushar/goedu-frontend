{
    "app": {
        "name": "ePathshala",
        "short_name": "ePathshala",
        "version": "1.0.0",
        "default_language": "en",
        "supported_languages": [
            "en",
            "bn"
        ]
    },
    "layout": {
        "module_bar": {
            "width": "64px",
            "position": "fixed",
            "logo": {
                "text": "ePathshala",
                "gradient": "from-blue-500 to-purple-600"
            }
        },
        "module_sidebar": {
            "width": "256px",
            "position": "fixed",
            "collapsible": true
        },
        "topbar": {
            "height": "56px",
            "position": "fixed",
            "show_breadcrumbs": true,
            "show_search": true,
            "show_notifications": true,
            "show_user_menu": true
        }
    },
    "modules": [
        {
            "id": "dashboard",
            "name": "Dashboard",
            "label": "Dashboard",
            "icon": "LayoutDashboardIcon",
            "color": "bg-indigo-600",
            "path": "/dashboard",
            "order": 2,
            "enabled": true,
            "required_permissions": [],
            "config_file": "dashboard-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "student-stats",
                "teacher-stats",
                "attendance-overview",
                "recent-activities",
                "quick-actions"
            ]
        },
        {
            "id": "academic",
            "name": "Academic",
            "label": "Academic",
            "icon": "BookOpen",
            "color": "bg-green-600",
            "path": "/academic",
            "order": 4,
            "enabled": true,
            "required_permissions": [],
            "config_file": "academic-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "academic-year",
                "session",
                "class",
                "section",
                "group",
                "shift",
                "subject"
            ]
        },
        {
            "id": "student",
            "name": "Student",
            "label": "Student",
            "icon": "UsersIcon",
            "color": "bg-teal-600",
            "path": "/student/dashboard",
            "order": 5,
            "enabled": true,
            "required_permissions": [],
            "config_file": "student-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "student-dashboard",
                "student-list",
                "student-registration",
                "student-profile",
                "student-promotion",
                "student-transfer",
                "student-documents"
            ]
        },
        {
            "id": "teacher",
            "name": "Teacher",
            "label": "Teacher",
            "icon": "UserCheck",
            "color": "bg-orange-600",
            "path": "/teacher",
            "order": 6,
            "enabled": true,
            "required_permissions": [],
            "config_file": "teacher-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "teacher-registration",
                "teacher-profile",
                "designation",
                "subject-assignment",
                "teacher-documents"
            ]
        },
        {
            "id": "attendance",
            "name": "Attendance",
            "label": "Attendance",
            "icon": "Calendar",
            "color": "bg-red-600",
            "path": "/attendance",
            "order": 8,
            "enabled": true,
            "required_permissions": [],
            "config_file": "attendance-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "student-attendance",
                "teacher-attendance",
                "staff-attendance",
                "daily-report",
                "monthly-report"
            ]
        },
        {
            "id": "routine",
            "name": "Routine",
            "label": "Routine",
            "icon": "LayoutDashboardIcon",
            "color": "bg-cyan-600",
            "path": "/routine/dashboard",
            "order": 10,
            "enabled": true,
            "required_permissions": [],
            "config_file": "routine-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "routine-dashboard",
                "class-routine",
                "teacher-routine",
                "exam-routine"
            ]
        },
        {
            "id": "examination",
            "name": "Exam",
            "label": "Exam",
            "icon": "FileText",
            "color": "bg-violet-600",
            "path": "/exam/dashboard",
            "order": 11,
            "enabled": true,
            "required_permissions": [],
            "config_file": "examination-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "exam-setup",
                "exam-schedule",
                "mark-entry",
                "grade-setup",
                "result-processing",
                "gpa-calculation"
            ]
        },
        {
            "id": "result",
            "name": "Result",
            "label": "Result",
            "icon": "Award",
            "color": "bg-emerald-600",
            "path": "/result",
            "order": 12,
            "enabled": true,
            "required_permissions": [],
            "config_file": "result-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "marksheet",
                "tabulation-sheet",
                "merit-list",
                "pass-list",
                "fail-list",
                "result-publish"
            ]
        },
        {
            "id": "website",
            "name": "Website",
            "label": "Website",
            "icon": "Globe",
            "color": "bg-sky-600",
            "path": "/website",
            "order": 14,
            "enabled": true,
            "required_permissions": [],
            "config_file": "website-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "homepage",
                "about",
                "notices",
                "gallery",
                "contact"
            ]
        },
        {
            "id": "reports",
            "name": "Reports",
            "label": "Reports Module",
            "icon": "BarChart",
            "color": "bg-rose-600",
            "path": "/reports",
            "order": 15,
            "enabled": true,
            "required_permissions": [],
            "config_file": "reports-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "student-reports",
                "teacher-reports",
                "attendance-reports",
                "result-reports"
            ]
        },
        {
            "id": "settings",
            "name": "Settings",
            "label": "System Settings",
            "icon": "Settings",
            "color": "bg-slate-700",
            "path": "/settings",
            "order": 16,
            "enabled": true,
            "required_permissions": [],
            "config_file": "settings-config.json",
            "has_sidebar": true,
            "contain_menus": [
                "settings-dashboard"
            ]
        }
    ],
    "global_permissions": {
        "DASHBOARD_VIEW": "Access main dashboard",
        "ACADEMIC_MODULE_ACCESS": "Access Academic module",
        "STUDENT_MODULE_ACCESS": "Access Student module",
        "TEACHER_MODULE_ACCESS": "Access Teacher module",
        "STAFF_MODULE_ACCESS": "Access Staff module",
        "ATTENDANCE_MODULE_ACCESS": "Access Attendance module",
        "SUBJECT_MODULE_ACCESS": "Access Subject module",
        "ROUTINE_MODULE_ACCESS": "Access Routine module",
        "EXAMINATION_MODULE_ACCESS": "Access Examination module",
        "RESULT_MODULE_ACCESS": "Access Result module",
        "NOTICE_MODULE_ACCESS": "Access Notice module",
        "WEBSITE_MODULE_ACCESS": "Access Website module",
        "REPORTS_MODULE_ACCESS": "Access Reports module",
        "SUPER_ADMIN": "Full system access"
    },
    "user_roles": {
        "super_admin": {
            "label": "Super Administrator",
            "permissions": [
                "SUPER_ADMIN"
            ]
        },
        "admin": {
            "label": "Administrator",
            "permissions": [
                "DASHBOARD_VIEW",
                "ACADEMIC_MODULE_ACCESS",
                "STUDENT_MODULE_ACCESS",
                "TEACHER_MODULE_ACCESS",
                "STAFF_MODULE_ACCESS",
                "ATTENDANCE_MODULE_ACCESS",
                "SUBJECT_MODULE_ACCESS",
                "ROUTINE_MODULE_ACCESS",
                "EXAMINATION_MODULE_ACCESS",
                "RESULT_MODULE_ACCESS",
                "NOTICE_MODULE_ACCESS",
                "WEBSITE_MODULE_ACCESS",
                "REPORTS_MODULE_ACCESS"
            ]
        }
    },
    "theme": {
        "primary_color": "blue",
        "sidebar_bg": "gray-900",
        "topbar_bg": "white",
        "content_bg": "gray-50",
        "dark_mode": false
    },
    "features": {
        "multi_language": true,
        "notifications": true,
        "search": true,
        "breadcrumbs": true,
        "user_profile": true,
        "help_system": true,
        "activity_logs": true
    }
}